# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/standupsync
JWT_SECRET=                          # min 32 chars: python -c "import secrets; print(secrets.token_hex(32))"
RESEND_API_KEY=re_xxx

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development              # development | production
FRONTEND_URL=http://localhost:3000

# ── Billing — Lemon Squeezy ───────────────────────────────────────────────────
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_STARTER_VARIANT_ID=

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_PROVIDER=mock                    # openai | anthropic | gemini | mock
LLM_API_KEY=                         # Gemini: get free key at aistudio.google.com → "Get API Key"
LLM_MODEL=                           # gpt-4o-mini | claude-3-haiku-20240307 | gemini-1.5-flash (auto-set if blank)

# ── Feature flags ─────────────────────────────────────────────────────────────
AI_TASK_RADAR_ADMIN_RUN=0            # set to 1 in dev to enable admin run backdoor
